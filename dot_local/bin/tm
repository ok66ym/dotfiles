#!/usr/bin/env zsh
# tm — Claude 状態アイコン付きの tmux セッション/ウィンドウ一覧

export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:$HOME/.local/share/aquaproj-aqua/bin:$HOME/.local/bin:$PATH"
#
# Claude Code hooks が /tmp/claude-status/<pane_id> に状態を書き込む前提:
#   running    → ⚡（ツール実行中）
#   permission → ❓（permission プロンプト待ち）
#   waiting    → ✅（応答完了・入力待ち）

_claude_icon() {
  local session="$1"
  local win_idx="$2"
  local best=""

  while IFS= read -r line; do
    local pane_id="${line%% *}"
    local pane_cmd="${line#* }"
    [[ -z "$pane_id" ]] && continue
    case "$pane_cmd" in
      zsh|bash|sh|fish|dash) continue ;;
    esac
    local status_file="/tmp/claude-status/$pane_id"
    [[ ! -f "$status_file" ]] && continue
    local pane_status
    pane_status=$(cat "$status_file" 2>/dev/null)
    case "$pane_status" in
      running)
        best="running"
        break
        ;;
      permission)
        [[ "$best" != "running" ]] && best="permission"
        ;;
      waiting)
        [[ -z "$best" ]] && best="waiting"
        ;;
    esac
  done < <(tmux list-panes -t "${session}:${win_idx}" -F "#{pane_id} #{pane_current_command}" 2>/dev/null)

  case "$best" in
    running)    echo " ⚡" ;;
    permission) echo " ❓" ;;
    waiting)    echo " ✅" ;;
    *)          echo "" ;;
  esac
}

# 1. 全セッション×ウィンドウのデータを収集
raw_data=()
while IFS= read -r entry; do
  raw_data+=("$entry")
done < <(tmux list-windows -a \
  -F "#{session_name}:#{window_index}:#{window_name}" 2>/dev/null)

if [[ ${#raw_data[@]} -eq 0 ]]; then
  echo "No tmux sessions found."
  exit 0
fi

# 2. セッション順序を並び替え: main を先頭、残りをアルファベット順
# 重複なしでセッション名を収集
all_sessions=()
for entry in "${raw_data[@]}"; do
  sname="${entry%%:*}"
  (( ${all_sessions[(Ie)$sname]} )) || all_sessions+=("$sname")
done

# main → その他アルファベット順
session_order=()
(( ${all_sessions[(Ie)main]} )) && session_order+=("main")
session_order+=(${(o)all_sessions:#main})

# raw_data をセッション順で再構築
sorted_data=()
for sess in "${session_order[@]}"; do
  for entry in "${raw_data[@]}"; do
    [[ "${entry%%:*}" == "$sess" ]] && sorted_data+=("$entry")
  done
done
raw_data=("${sorted_data[@]}")

# 4. 全セッション名の最大長を計算（window 情報の開始列をグローバルに揃えるため）
max_len=0
for entry in "${raw_data[@]}"; do
  sname="${entry%%:*}"
  (( ${#sname} > max_len )) && max_len=${#sname}
done
(( max_len < 1 )) && max_len=1

# 5. ツリー表示のための行を構築
#
#    max_len でセッション名列の幅を統一し、全行で win_idx:win_name が
#    同じ列から始まるようにする。
#
#    例 (max_len=26):
#      main                        1:server   ⚡
#                                  2:nvim
#      feature-implement-NDE-1234  1:server   ✅
#                                  2:nvim
#                                  3:cl
#
#    フォーマット: session<TAB>win_idx<TAB>display
#    TAB 区切りにすることで ":" と衝突しない。
#    printf "%-${max_len}s" でセッション名を左詰め固定幅にする。
#    printf "%${max_len}s" "" でスペース padding（右詰め空文字 = 空白 max_len 個）。

TAB=$'\t'
lines=()
prev_sess=""

# セパレータ: dim スタイルの細い水平線（空行の代わりに軽い区切りとして使用）
# max_len + 30 ≈ セッション名列 + ウィンドウ情報列の幅
_sep_width=$(( max_len + 30 ))
_sep_line=$'\033[2m'$(printf '─%.0s' {1..$_sep_width})$'\033[0m'

for entry in "${raw_data[@]}"; do
  session="${entry%%:*}"
  rest="${entry#*:}"
  win_idx="${rest%%:*}"
  win_name="${rest#*:}"

  icon=$(_claude_icon "$session" "$win_idx")

  if [[ "$session" != "$prev_sess" ]]; then
    # セッションが変わる直前にセパレータを挿入（初回グループは除く）
    [[ -n "$prev_sess" ]] && lines+=("${TAB}${TAB}${_sep_line}")
    prefix=$(printf "%-${max_len}s" "$session")
    prev_sess="$session"
  else
    # 同セッションの 2 つ目以降: max_len 個のスペースでインデント
    prefix=$(printf "%${max_len}s" "")
  fi

  display="${prefix}  ${win_idx}:$(printf '%-25s' "$win_name")${icon}"
  lines+=("${session}${TAB}${win_idx}${TAB}${display}")
done

# 6. fzf で選択（TAB を delimiter にして display フィールドのみ表示）
selection=$(printf '%s\n' "${lines[@]}" \
  | fzf --prompt="Session/Window > " \
        --height=80% --layout=reverse --border \
        --delimiter="$TAB" --with-nth=3 \
        --header="⚡ running  ✅ done  ❓ permission" \
        --ansi)

[[ -z "$selection" ]] && exit 0

# 7. TAB 区切りで session と win_idx を取り出す
# セパレータ行（session/win_idx が空）を選択した場合は何もしない
session="${selection%%$TAB*}"
rest="${selection#*$TAB}"
win_idx="${rest%%$TAB*}"
[[ -z "$session" || -z "$win_idx" ]] && exit 0

tmux switch-client -t "${session}:${win_idx}" 2>/dev/null \
  || tmux select-window -t "${session}:${win_idx}" 2>/dev/null

# worktree セッションへの切替ならサーバーを管理する（バックグラウンドで即時実行）
zsh ~/.local/bin/tm-wt --server-switch "$session" &>/dev/null &
