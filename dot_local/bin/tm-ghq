#!/usr/bin/env zsh
# tm-ghq — ghq 管理リポジトリを fzf で選択し tmux セッションを切替 or 新規作成

export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:$HOME/.local/share/aquaproj-aqua/bin:$HOME/.local/bin:$PATH"

ghq_root=$(ghq root 2>/dev/null)
if [[ -z "$ghq_root" ]]; then
  echo "Error: ghq not found or ghq root is empty."
  exit 1
fi

repo=$(ghq list 2>/dev/null \
  | fzf --prompt="Repository > " \
        --height=80% --layout=reverse --border \
        --header="Select repository (Enter: switch/create session)")
[[ -z "$repo" ]] && exit 0

repo_path="$ghq_root/$repo"
# セッション名はリポジトリ名の最後のコンポーネント（例: CFO-Alpha）
session_name=$(basename "$repo")

if tmux has-session -t "=$session_name" 2>/dev/null; then
  tmux switch-client -t "=$session_name"
else
  tmux new-session -d -s "$session_name" -c "$repo_path"
  tmux switch-client -t "=$session_name"
fi
